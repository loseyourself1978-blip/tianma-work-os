{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/loseyourself1978-blip/tianma-work-os/schemas/ui_boundary_architecture_review.schema.json",
  "title": "UI Boundary Architecture Review",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_type",
    "review_id",
    "project",
    "subproject",
    "review_time",
    "baseline_checkpoint",
    "baseline_commit",
    "portfolio_mode",
    "source_view_model",
    "boundary_artifacts",
    "surface_ids",
    "visibility_classes",
    "state_taxonomies",
    "allowed_interactions",
    "prohibited_capabilities",
    "validation_status",
    "blocking_issues",
    "warnings",
    "customer_facing_ready",
    "recommended_next_phase",
    "explicit_confirmations",
    "related_records",
    "related_reports"
  ],
  "properties": {
    "schema_type": {
      "type": "string",
      "enum": [
        "ui_boundary_architecture_review"
      ]
    },
    "review_id": {
      "type": "string"
    },
    "project": {
      "type": "string"
    },
    "subproject": {
      "type": "string"
    },
    "review_time": {
      "type": "string"
    },
    "baseline_checkpoint": {
      "type": "string"
    },
    "baseline_commit": {
      "type": "string"
    },
    "portfolio_mode": {
      "type": "string"
    },
    "source_view_model": {
      "type": "string"
    },
    "boundary_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "surface_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "visibility_classes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "state_taxonomies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "allowed_interactions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "prohibited_capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation_status": {
      "type": "string",
      "enum": [
        "passed",
        "passed_with_warnings",
        "failed"
      ]
    },
    "blocking_issues": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "customer_facing_ready": {
      "type": "boolean"
    },
    "recommended_next_phase": {
      "type": "string"
    },
    "explicit_confirmations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "related_records": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "related_reports": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
