{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/loseyourself1978-blip/tianma-work-os/schemas/vol7_local_static_shell_demo_pack.schema.json",
  "title": "Vol.7 Local Static Shell Demo Pack",
  "description": "Validates the Vol.7 Phase 7.6 local static shell demo pack and operator walkthrough fixture.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "phase",
    "baseline_commit",
    "demo_pack_status",
    "operator_walkthrough_status",
    "demo_checklist_status",
    "safety_boundary_status",
    "local_static_shell_path",
    "required_demo_documents",
    "required_panels",
    "required_guardrail_labels",
    "ldd_backfeed_sections",
    "forbidden_affordances",
    "forbidden_integrations",
    "fixture_only",
    "read_only",
    "local_static_preview_only",
    "network_allowed",
    "api_allowed",
    "mutation_allowed",
    "execution_allowed",
    "credential_handling_allowed",
    "live_data_allowed",
    "customer_facing_readiness",
    "production_deployment_allowed",
    "warnings",
    "errors"
  ],
  "properties": {
    "phase": {
      "type": "string",
      "enum": ["Vol.7 Phase 7.6 - Local Static Shell Demo Pack and Operator Walkthrough"]
    },
    "baseline_commit": {
      "type": "string",
      "enum": ["5801c03a735fac578d1b382a716927060cbfb0ec"]
    },
    "demo_pack_status": {"type": "string", "enum": ["passed"]},
    "operator_walkthrough_status": {"type": "string", "enum": ["passed"]},
    "demo_checklist_status": {"type": "string", "enum": ["passed"]},
    "safety_boundary_status": {"type": "string", "enum": ["passed"]},
    "local_static_shell_path": {"type": "string", "enum": ["static_shell/ldd/index.html"]},
    "required_demo_documents": {"type": "array", "items": {"type": "string"}},
    "required_panels": {"type": "array", "items": {"type": "string"}},
    "required_guardrail_labels": {"type": "array", "items": {"type": "string"}},
    "ldd_backfeed_sections": {"type": "array", "items": {"type": "string"}},
    "forbidden_affordances": {"type": "array", "items": {"type": "string"}},
    "forbidden_integrations": {"type": "array", "items": {"type": "string"}},
    "fixture_only": {"type": "boolean", "enum": [true]},
    "read_only": {"type": "boolean", "enum": [true]},
    "local_static_preview_only": {"type": "boolean", "enum": [true]},
    "network_allowed": {"type": "boolean", "enum": [false]},
    "api_allowed": {"type": "boolean", "enum": [false]},
    "mutation_allowed": {"type": "boolean", "enum": [false]},
    "execution_allowed": {"type": "boolean", "enum": [false]},
    "credential_handling_allowed": {"type": "boolean", "enum": [false]},
    "live_data_allowed": {"type": "boolean", "enum": [false]},
    "customer_facing_readiness": {"type": "boolean", "enum": [false]},
    "production_deployment_allowed": {"type": "boolean", "enum": [false]},
    "warnings": {"type": "array", "items": {"type": "string"}, "maxItems": 0},
    "errors": {"type": "array", "items": {"type": "string"}, "maxItems": 0}
  }
}
