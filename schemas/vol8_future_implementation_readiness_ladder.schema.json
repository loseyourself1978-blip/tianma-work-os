      "type": "array",
      "items": {"type": ["object", "string"]}
    },
    "summary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "total_ladder_items",
        "count_by_readiness_level",
        "count_by_required_gate_type",
        "static_ready_count",
        "roadmap_only_count",
        "future_gate_required_count",
        "rejected_forbidden_scope_count",
        "deferred_out_of_scope_count",
        "execution_governance_required_count",
        "network_api_gate_required_count",
        "customer_facing_gate_required_count",
        "security_credential_gate_required_count",
        "boundary_risk_notes",
        "recommended_next_action"
      ],
      "properties": {
        "total_ladder_items": {"type": "integer"},
        "count_by_readiness_level": {"type": "object"},
        "count_by_required_gate_type": {"type": "object"},
        "static_ready_count": {"type": "integer"},
        "roadmap_only_count": {"type": "integer"},
        "future_gate_required_count": {"type": "integer"},
        "rejected_forbidden_scope_count": {"type": "integer"},
        "deferred_out_of_scope_count": {"type": "integer"},
        "execution_governance_required_count": {"type": "integer"},
        "network_api_gate_required_count": {"type": "integer"},
        "customer_facing_gate_required_count": {"type": "integer"},
        "security_credential_gate_required_count": {"type": "integer"},
        "boundary_risk_notes": {"type": "array", "items": {"type": "string"}},
        "recommended_next_action": {"type": "string"}
      }
    },
    "forbidden_scope_confirmed_absent": {"type": "array", "items": {"type": "string"}},
    "recommended_next_phase": {"type": "string"}
  }
}
