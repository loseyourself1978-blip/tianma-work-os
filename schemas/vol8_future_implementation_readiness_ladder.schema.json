{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/loseyourself1978-blip/tianma-work-os/schemas/vol8_future_implementation_readiness_ladder.schema.json",
  "title": "Vol.8 Future Implementation Readiness Ladder",
  "description": "Validates the local static-only future implementation readiness ladder fixture for Vol.8 Phase 8.5.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "phase",
    "baseline_commit",
    "runtime_records",
    "static_shell_path",
    "customer_facing_readiness",
    "source_boundary_map",
    "readiness_items",
    "summary",
    "forbidden_scope_confirmed_absent",
    "recommended_next_phase"
  ],
  "properties": {
    "phase": {"type": "string", "enum": ["Vol.8 Phase 8.5 - Future Implementation Readiness Ladder"]},
    "baseline_commit": {"type": "string", "enum": ["59401955f861af4c1313b2973d1528278474cc18"]},
    "runtime_records": {"type": "integer", "enum": [112]},
    "static_shell_path": {"type": "string", "enum": ["static_shell/ldd/"]},
    "customer_facing_readiness": {"type": "boolean", "enum": [false]},
