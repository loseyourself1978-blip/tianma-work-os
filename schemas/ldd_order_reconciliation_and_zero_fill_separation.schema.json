{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/loseyourself1978-blip/tianma-work-os/schemas/ldd_order_reconciliation_and_zero_fill_separation.schema.json",
  "title": "LDD Order Reconciliation and Zero-Fill Separation",
  "description": "Validates the static Phase 9.7 order reconciliation and zero-fill separation fixture.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "gate_name",
    "phase",
    "generated_at_sgt",
    "state_name",
    "order_reconciliation_gate_created",
    "zero_fill_order_separation_created",
    "event_classes",
    "spcx_order_reconciliation",
    "execution_ledger_impact",
    "trading_state_impact",
    "source_of_truth_boundary",
    "non_activation_rules",
    "acceptance"
  ],
  "properties": {
    "schema_version": {"type": "string", "enum": ["0.1"]},
    "gate_name": {"type": "string", "enum": ["ldd_order_reconciliation_and_zero_fill_separation"]},
    "phase": {"type": "string", "enum": ["Vol.9 Phase 9.7"]},
    "generated_at_sgt": {"type": "string"},
    "state_name": {"type": "string", "enum": ["order_reconciliation_gate_created", "zero_fill_order_separation_created", "execution_ledger_gap_closed"]},
    "order_reconciliation_gate_created": {"type": "boolean", "enum": [true]},
    "zero_fill_order_separation_created": {"type": "boolean", "enum": [true]},
    "event_classes": {"type": "array", "items": {"type": "string"}},
    "spcx_order_reconciliation": {
      "type": "object",
      "required": [
        "symbol",
        "name",
        "direction",
        "limit_price_usd",
        "quantity",
        "filled_quantity",
        "reference_current_price_usd_approx",
        "status",
        "classification",
        "filled_trade_occurred",
        "position_created",
        "cash_impact_occurred",
        "confirmed_filled_us_orders",
        "expired_order_count"
      ],
      "properties": {
        "symbol": {"type": "string", "enum": ["SPCX"]},
        "name": {"type": "string", "enum": ["SpaceX"]},
        "direction": {"type": "string", "enum": ["buy"]},
        "limit_price_usd": {"type": "number", "enum": [150.0]},
        "quantity": {"type": "integer", "enum": [10]},
        "filled_quantity": {"type": "integer", "enum": [0]},
        "reference_current_price_usd_approx": {"type": "number", "enum": [192.39]},
        "status": {"type": "string", "enum": ["expired"]},
        "classification": {"type": "string", "enum": ["expired_zero_fill_order"]},
        "filled_trade_occurred": {"type": "boolean", "enum": [false]},
        "position_created": {"type": "boolean", "enum": [false]},
        "cash_impact_occurred": {"type": "boolean", "enum": [false]},
        "confirmed_filled_us_orders": {"type": "integer", "enum": [0]},
        "expired_order_count": {"type": "integer", "enum": [1]}
      }
    },
    "execution_ledger_impact": {"type": "object"},
    "trading_state_impact": {"type": "object"},
    "source_of_truth_boundary": {"type": "object"},
    "non_activation_rules": {"type": "array", "items": {"type": "string"}},
    "acceptance": {"type": "object"}
  }
}
