{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/loseyourself1978-blip/tianma-work-os/schemas/vol7_handoff_summary.schema.json",
  "title": "Vol.7 Handoff Summary",
  "description": "Validates the Vol.7 handoff summary fixture and Phase 7.8 runtime record.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "phase",
    "baseline_commit",
    "vol7_status",
    "handoff_status",
    "completed_phase_count",
    "completed_phases",
    "runtime_records_count",
    "timeline_event_count",
    "timeline_warning_count",
    "customer_facing_readiness",
    "static_shell_path",
    "static_shell_boundary_status",
    "snapshot_qa_status",
    "completion_readiness",
    "ldd_backfeed_coverage",
    "forbidden_scope_absence_status",
    "fixture_only",
    "read_only",
    "local_static_preview_only",
    "network_allowed",
    "api_allowed",
    "mutation_allowed",
    "execution_allowed",
    "credential_handling_allowed",
    "live_data_allowed",
    "production_deployment_allowed",
    "warnings",
    "errors"
  ],
  "properties": {
    "phase": {
      "type": "string",
      "enum": ["Vol.7 Phase 7.8 - Vol.7 Handoff Summary and Vol.8 Readiness Gate"]
    },
    "baseline_commit": {
      "type": "string",
      "enum": ["e31014b9fbb56d37c8ad566a3c637e995befcbe0"]
    },
    "vol7_status": {"type": "string", "enum": ["completed"]},
    "handoff_status": {"type": "string", "enum": ["ready"]},
    "completed_phase_count": {"type": "integer", "enum": [9]},
    "completed_phases": {"type": "array", "items": {"type": "string"}},
    "runtime_records_count": {"type": "integer", "minimum": 108},
    "timeline_event_count": {"type": "integer", "minimum": 108},
    "timeline_warning_count": {"type": "integer", "enum": [0]},
    "customer_facing_readiness": {"type": "boolean", "enum": [false]},
    "static_shell_path": {"type": "string", "enum": ["static_shell/ldd/"]},
    "static_shell_boundary_status": {"type": "string", "enum": ["passed"]},
    "snapshot_qa_status": {"type": "string", "enum": ["passed"]},
    "completion_readiness": {"type": "string", "enum": ["ready_for_handoff"]},
    "ldd_backfeed_coverage": {"type": "string", "enum": ["passed"]},
    "forbidden_scope_absence_status": {"type": "string", "enum": ["passed"]},
    "fixture_only": {"type": "boolean", "enum": [true]},
    "read_only": {"type": "boolean", "enum": [true]},
    "local_static_preview_only": {"type": "boolean", "enum": [true]},
    "network_allowed": {"type": "boolean", "enum": [false]},
    "api_allowed": {"type": "boolean", "enum": [false]},
    "mutation_allowed": {"type": "boolean", "enum": [false]},
    "execution_allowed": {"type": "boolean", "enum": [false]},
    "credential_handling_allowed": {"type": "boolean", "enum": [false]},
    "live_data_allowed": {"type": "boolean", "enum": [false]},
    "production_deployment_allowed": {"type": "boolean", "enum": [false]},
    "warnings": {"type": "array", "items": {"type": "string"}, "maxItems": 0},
    "errors": {"type": "array", "items": {"type": "string"}, "maxItems": 0}
  }
}
