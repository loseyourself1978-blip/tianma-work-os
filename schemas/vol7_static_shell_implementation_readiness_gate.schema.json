{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/loseyourself1978-blip/tianma-work-os/schemas/vol7_static_shell_implementation_readiness_gate.schema.json",
  "title": "Vol.7 Static Shell Implementation Readiness Gate",
  "description": "Validates the Vol.7 Phase 7.3 static shell implementation readiness gate fixture and record.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "phase",
    "baseline_commit",
    "readiness_gate_timestamp",
    "active_checkpoint",
    "latest_timeline_event",
    "runtime_records_count",
    "timeline_event_count",
    "timeline_warning_count",
    "active_rules_count",
    "strategy_states_count",
    "operating_mode",
    "portfolio_mode",
    "dry_run_status",
    "dry_run_warning_count",
    "dry_run_error_count",
    "drift_status",
    "critical_drift_count",
    "warning_drift_count",
    "static_shell_implementation_readiness",
    "customer_facing_readiness",
    "fixture_only",
    "read_only",
    "mutation_allowed",
    "execution_allowed",
    "credential_handling_allowed",
    "live_data_allowed",
    "required_labels",
    "ldd_scope_reminder",
    "future_implementation_permission_envelope",
    "required_guardrails",
    "ldd_premarket_backfeed_reviewed",
    "ldd_premarket_backfeed_timestamp",
    "quote_drift_display_layer_required",
    "quote_type_tagging_required",
    "holdings_candidate_forbidden_radar_separation_required",
    "cash_defense_ratio_split_required",
    "transfer_pnl_separation_required",
    "ggll_state_correction_required",
    "ggll_current_state",
    "zec_grid_state",
    "usdt_defense_floor_required",
    "usdt_defense_floor"
  ],
  "properties": {
    "phase": {"type": "string"},
    "baseline_commit": {"type": "string"},
    "readiness_gate_timestamp": {"type": "string"},
    "active_checkpoint": {"type": "string", "enum": ["2026-06-12T09:18:00+08:00"]},
    "latest_timeline_event": {"type": "string"},
    "runtime_records_count": {"type": "integer"},
    "timeline_event_count": {"type": "integer"},
    "timeline_warning_count": {"type": "integer", "enum": [0]},
    "active_rules_count": {"type": "integer", "enum": [11]},
    "strategy_states_count": {"type": "integer", "enum": [16]},
    "operating_mode": {"type": "string", "enum": ["cash_defense_core_position_survival_mode"]},
    "portfolio_mode": {"type": "string", "enum": ["residual_core_position_mode"]},
    "dry_run_status": {"type": "string", "enum": ["passed"]},
    "dry_run_warning_count": {"type": "integer", "enum": [0]},
    "dry_run_error_count": {"type": "integer", "enum": [0]},
    "drift_status": {"type": "string", "enum": ["no_drift_detected"]},
    "critical_drift_count": {"type": "integer", "enum": [0]},
    "warning_drift_count": {"type": "integer", "enum": [0]},
    "static_shell_implementation_readiness": {"type": "string", "enum": ["ready_with_limits"]},
    "customer_facing_readiness": {"type": "boolean", "enum": [false]},
    "fixture_only": {"type": "boolean", "enum": [true]},
    "read_only": {"type": "boolean", "enum": [true]},
    "mutation_allowed": {"type": "boolean", "enum": [false]},
    "execution_allowed": {"type": "boolean", "enum": [false]},
    "credential_handling_allowed": {"type": "boolean", "enum": [false]},
    "live_data_allowed": {"type": "boolean", "enum": [false]},
    "required_labels": {"type": "array", "items": {"type": "string"}},
    "ldd_scope_reminder": {"type": "string"},
    "future_implementation_permission_envelope": {"type": "object"},
    "required_guardrails": {"type": "array", "items": {"type": "string"}},
    "ldd_premarket_backfeed_reviewed": {"type": "boolean", "enum": [true]},
    "ldd_premarket_backfeed_timestamp": {"type": "string", "enum": ["2026-06-15T17:06:00+08:00"]},
    "quote_drift_display_layer_required": {"type": "boolean", "enum": [true]},
    "quote_type_tagging_required": {"type": "boolean", "enum": [true]},
    "holdings_candidate_forbidden_radar_separation_required": {"type": "boolean", "enum": [true]},
    "cash_defense_ratio_split_required": {"type": "boolean", "enum": [true]},
    "transfer_pnl_separation_required": {"type": "boolean", "enum": [true]},
    "ggll_state_correction_required": {"type": "boolean", "enum": [true]},
    "ggll_current_state": {"type": "string", "enum": ["zero_position_not_residual_risk_valve"]},
    "zec_grid_state": {"type": "string", "enum": ["closed_no_reopen"]},
    "usdt_defense_floor_required": {"type": "boolean", "enum": [true]},
    "usdt_defense_floor": {"type": "number", "enum": [0.7]}
  }
}
