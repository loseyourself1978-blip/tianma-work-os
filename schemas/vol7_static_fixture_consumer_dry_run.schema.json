{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/loseyourself1978-blip/tianma-work-os/schemas/vol7_static_fixture_consumer_dry_run.schema.json",
  "title": "Vol.7 Static Fixture Consumer Dry-Run Result",
  "description": "Validates the static fixture consumer dry-run result for Vol.7 Phase 7.2.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "phase",
    "baseline_commit",
    "dry_run_timestamp",
    "input_fixtures_checked",
    "input_fixture_count",
    "all_required_fixtures_present",
    "all_required_fields_present",
    "all_static_flags_valid",
    "all_panels_read_only",
    "all_forbidden_actions_disabled",
    "all_forbidden_integrations_absent",
    "ldd_scope_reminder_present",
    "customer_facing_readiness",
    "dry_run_status",
    "warnings",
    "errors",
    "fixture_only",
    "read_only",
    "mutation_allowed",
    "execution_allowed",
    "credential_handling_allowed",
    "live_data_allowed"
  ],
  "properties": {
    "phase": {"description": "Vol.7 Phase 7.2 phase label.", "type": "string"},
    "baseline_commit": {"description": "Baseline commit used for the dry-run.", "type": "string"},
    "dry_run_timestamp": {"description": "Dry-run timestamp.", "type": "string"},
    "input_fixtures_checked": {"description": "Allowed static fixtures loaded by the dry-run.", "type": "array", "items": {"type": "string"}},
    "input_fixture_count": {"description": "Number of input fixtures checked.", "type": "integer"},
    "all_required_fixtures_present": {"description": "All required fixtures exist.", "type": "boolean", "enum": [true]},
    "all_required_fields_present": {"description": "All required fields are present.", "type": "boolean", "enum": [true]},
    "all_static_flags_valid": {"description": "Static flags are valid across fixtures.", "type": "boolean", "enum": [true]},
    "all_panels_read_only": {"description": "All panels are read-only.", "type": "boolean", "enum": [true]},
    "all_forbidden_actions_disabled": {"description": "Forbidden actions are disabled or absent.", "type": "boolean", "enum": [true]},
    "all_forbidden_integrations_absent": {"description": "Forbidden integrations are absent.", "type": "boolean", "enum": [true]},
    "ldd_scope_reminder_present": {"description": "The LDD full-market scope reminder is present.", "type": "boolean", "enum": [true]},
    "customer_facing_readiness": {"description": "Customer-facing readiness remains false.", "type": "boolean", "enum": [false]},
    "dry_run_status": {"description": "Dry-run pass/fail status.", "type": "string", "enum": ["passed"]},
    "warnings": {"description": "Dry-run warnings.", "type": "array", "items": {"type": "string"}},
    "errors": {"description": "Dry-run errors.", "type": "array", "items": {"type": "string"}},
    "fixture_only": {"description": "Dry-run result is fixture-only.", "type": "boolean", "enum": [true]},
    "read_only": {"description": "Dry-run result is read-only.", "type": "boolean", "enum": [true]},
    "mutation_allowed": {"description": "Mutation is disallowed.", "type": "boolean", "enum": [false]},
    "execution_allowed": {"description": "Execution is disallowed.", "type": "boolean", "enum": [false]},
    "credential_handling_allowed": {"description": "Credential handling is disallowed.", "type": "boolean", "enum": [false]},
    "live_data_allowed": {"description": "Live data is disallowed.", "type": "boolean", "enum": [false]}
  }
}
