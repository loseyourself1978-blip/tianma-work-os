{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/loseyourself1978-blip/tianma-work-os/schemas/static_prototype_evidence_pack.schema.json",
  "title": "Static Prototype Evidence Pack",
  "description": "Validates the static Phase 9.4 prototype evidence pack.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "evidence_pack_name",
    "phase",
    "generated_at_sgt",
    "baseline",
    "static_evidence_pack_created",
    "evidence_categories",
    "source_of_truth_separation",
    "quote_type_preservation",
    "execution_event_distinction",
    "forbidden_scope",
    "acceptance"
  ],
  "properties": {
    "schema_version": {"type": "string", "enum": ["0.1"]},
    "evidence_pack_name": {"type": "string", "enum": ["static_prototype_evidence_pack"]},
    "phase": {"type": "string", "enum": ["Vol.9 Phase 9.4"]},
    "generated_at_sgt": {"type": "string"},
    "static_evidence_pack_created": {"type": "boolean", "enum": [true]},
    "baseline": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "latest_completed_phase_before_phase",
        "latest_commit_before_phase",
        "customer_facing_readiness",
        "live_runtime_execution_frameworks",
        "static_shell_mode"
      ],
      "properties": {
        "latest_completed_phase_before_phase": {"type": "string", "enum": ["Vol.9 Phase 9.3"]},
        "latest_commit_before_phase": {"type": "string", "enum": ["0bf392e98ae0b4f3ea7236af03f563983d7dfa5b"]},
        "customer_facing_readiness": {"type": "boolean", "enum": [false]},
        "live_runtime_execution_frameworks": {"type": "integer", "enum": [0]},
        "static_shell_mode": {"type": "string", "enum": ["local_static_read_only_fixture_only_no_network_no_execution"]}
      }
    },
    "evidence_categories": {"type": "object"},
    "source_of_truth_separation": {"type": "object"},
    "quote_type_preservation": {"type": "array", "items": {"type": "string"}},
    "execution_event_distinction": {"type": "array", "items": {"type": "string"}},
    "forbidden_scope": {"type": "array", "items": {"type": "string"}},
    "acceptance": {"type": "object"}
  }
}
