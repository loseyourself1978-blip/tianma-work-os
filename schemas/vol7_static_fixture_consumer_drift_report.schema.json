{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/loseyourself1978-blip/tianma-work-os/schemas/vol7_static_fixture_consumer_drift_report.schema.json",
  "title": "Vol.7 Static Fixture Consumer Drift Report",
  "description": "Validates the static fixture consumer drift report for Vol.7 Phase 7.2.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "phase",
    "baseline_commit",
    "drift_check_timestamp",
    "drift_status",
    "drift_categories_checked",
    "drift_findings",
    "critical_drift_count",
    "warning_drift_count",
    "info_drift_count",
    "scope_reminder_valid",
    "read_only_guards_valid",
    "customer_facing_readiness",
    "fixture_only",
    "read_only",
    "mutation_allowed",
    "execution_allowed",
    "credential_handling_allowed",
    "live_data_allowed"
  ],
  "properties": {
    "phase": {"description": "Vol.7 Phase 7.2 phase label.", "type": "string"},
    "baseline_commit": {"description": "Baseline commit used for drift detection.", "type": "string"},
    "drift_check_timestamp": {"description": "Drift check timestamp.", "type": "string"},
    "drift_status": {"description": "Drift status.", "type": "string", "enum": ["no_drift_detected"]},
    "drift_categories_checked": {"description": "Drift categories checked.", "type": "array", "items": {"type": "string"}},
    "drift_findings": {"description": "Detected drift findings.", "type": "array", "items": {"type": "object"}},
    "critical_drift_count": {"description": "Critical drift count.", "type": "integer", "enum": [0]},
    "warning_drift_count": {"description": "Warning drift count.", "type": "integer", "enum": [0]},
    "info_drift_count": {"description": "Informational drift count.", "type": "integer"},
    "scope_reminder_valid": {"description": "Full-market scope reminder remains valid.", "type": "boolean", "enum": [true]},
    "read_only_guards_valid": {"description": "Read-only guards remain valid.", "type": "boolean", "enum": [true]},
    "customer_facing_readiness": {"description": "Customer-facing readiness remains false.", "type": "boolean", "enum": [false]},
    "fixture_only": {"description": "Drift report is fixture-only.", "type": "boolean", "enum": [true]},
    "read_only": {"description": "Drift report is read-only.", "type": "boolean", "enum": [true]},
    "mutation_allowed": {"description": "Mutation is disallowed.", "type": "boolean", "enum": [false]},
    "execution_allowed": {"description": "Execution is disallowed.", "type": "boolean", "enum": [false]},
    "credential_handling_allowed": {"description": "Credential handling is disallowed.", "type": "boolean", "enum": [false]},
    "live_data_allowed": {"description": "Live data is disallowed.", "type": "boolean", "enum": [false]}
  }
}
