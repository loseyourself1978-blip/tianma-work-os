{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/loseyourself1978-blip/tianma-work-os/schemas/prototype_to_gate_traceability_map.schema.json",
  "title": "Prototype-to-Gate Traceability Map",
  "description": "Validates the static Phase 9.6 prototype-to-gate traceability map.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "traceability_map_name",
    "phase",
    "generated_at_sgt",
    "state_name",
    "prototype_to_gate_traceability_map_created",
    "future_gate_activation",
    "future_gates",
    "artifact_traceability_rules",
    "future_gaps",
    "customer_facing_readiness",
    "live_runtime_execution_frameworks",
    "static_shell_mode",
    "non_activation_rules",
    "required_conditions",
    "acceptance"
  ],
  "properties": {
    "schema_version": {"type": "string", "enum": ["0.1"]},
    "traceability_map_name": {"type": "string", "enum": ["prototype_to_gate_traceability_map"]},
    "phase": {"type": "string", "enum": ["Vol.9 Phase 9.6"]},
    "generated_at_sgt": {"type": "string"},
    "state_name": {"type": "string", "enum": ["static_shell_traceability_map_created", "prototype_to_gate_traceability_map_created", "future_gate_activation_blocked"]},
    "prototype_to_gate_traceability_map_created": {"type": "boolean", "enum": [true]},
    "future_gate_activation": {"type": "boolean", "enum": [false]},
    "future_gates": {"type": "object"},
    "artifact_traceability_rules": {"type": "object"},
    "future_gaps": {"type": "object"},
    "customer_facing_readiness": {"type": "boolean", "enum": [false]},
    "live_runtime_execution_frameworks": {"type": "integer", "enum": [0]},
    "static_shell_mode": {"type": "string", "enum": ["local_static_read_only_fixture_only_no_network_no_execution"]},
    "non_activation_rules": {"type": "array", "items": {"type": "string"}},
    "required_conditions": {"type": "array", "items": {"type": "string"}},
    "acceptance": {"type": "object"}
  }
}
