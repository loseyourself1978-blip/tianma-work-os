    "phase",
    "sync_type",
    "review_type",
    "timestamp_sgt",
    "timestamp_range_sgt_bjt",
    "market_session",
    "source_priority",
    "runtime_baseline_correction",
    "active_checkpoint_before_this_review",
    "active_checkpoint_after_this_review",
    "checkpoint_promoted",
    "promotion_reason",
    "operating_mode_before",
    "operating_mode_after",
    "portfolio_mode_after",
    "customer_facing_ready",
    "external_api_connected",
    "broker_api_connected",
    "binance_api_connected",
    "live_market_data_enabled",
    "trading_automation_enabled",
    "credential_handling_enabled",
    "runtime_mutation_enabled_by_user_interface",
    "execution_trigger_enabled_by_system",
    "account_update",
    "current_us_positions",
