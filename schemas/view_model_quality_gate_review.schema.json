{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/loseyourself1978-blip/tianma-work-os/schemas/view_model_quality_gate_review.schema.json",
  "title": "View Model Quality Gate Review",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_type",
    "review_id",
    "project",
    "subproject",
    "review_time",
    "baseline_checkpoint",
    "baseline_commit",
    "portfolio_mode",
    "view_model_file",
    "quality_gate_version",
    "gates_checked",
    "validation_status",
    "blocking_failures",
    "warnings",
    "expected_counts",
    "findings",
    "non_goals",
    "recommended_next_phase",
    "related_records",
    "related_reports"
  ],
  "properties": {
    "schema_type": {
      "type": "string",
      "enum": [
        "view_model_quality_gate_review"
      ]
    },
    "review_id": {
      "type": "string"
    },
    "project": {
      "type": "string"
    },
    "subproject": {
      "type": "string"
    },
    "review_time": {
      "type": "string"
    },
    "baseline_checkpoint": {
      "type": "string"
    },
    "baseline_commit": {
      "type": "string"
    },
    "portfolio_mode": {
      "type": "string"
    },
    "view_model_file": {
      "type": "string"
    },
    "quality_gate_version": {
      "type": "string"
    },
    "gates_checked": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation_status": {
      "type": "string",
      "enum": [
        "passed",
        "passed_with_warnings",
        "failed"
      ]
    },
    "blocking_failures": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "expected_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "active_rules",
        "strategy_states",
        "timeline_events",
        "timeline_warnings"
      ],
      "properties": {
        "active_rules": {
          "type": "integer"
        },
        "strategy_states": {
          "type": "integer"
        },
        "timeline_events": {
          "type": "integer"
        },
        "timeline_warnings": {
          "type": "integer"
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "non_goals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommended_next_phase": {
      "type": "string"
    },
    "related_records": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "related_reports": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
