{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/loseyourself1978-blip/tianma-work-os/schemas/vol7_static_fixture_consumer_contract.schema.json",
  "title": "Vol.7 Static Fixture Consumer Contract",
  "description": "Validates the static fixture consumer contract for Vol.7 Phase 7.1.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "phase",
    "baseline_commit",
    "origin_status",
    "working_tree_status",
    "active_checkpoint",
    "latest_timeline_event",
    "runtime_records_count",
    "timeline_event_count",
    "timeline_warning_count",
    "active_rules_count",
    "strategy_states_count",
    "customer_facing_readiness",
    "operating_mode",
    "portfolio_mode",
    "allowed_input_fixtures",
    "normalized_view_model_contract",
    "required_labels",
    "forbidden_affordances",
    "forbidden_integrations",
    "fixture_only",
    "read_only",
    "mutation_allowed",
    "execution_allowed",
    "credential_handling_allowed",
    "live_data_allowed",
    "ldd_scope_reminder"
  ],
  "properties": {
    "phase": {"description": "Vol.7 Phase 7.1 phase label.", "type": "string"},
    "baseline_commit": {"description": "Baseline commit for the contract.", "type": "string"},
    "origin_status": {"description": "Origin sync status.", "type": "string"},
    "working_tree_status": {"description": "Working tree status at baseline.", "type": "string"},
    "active_checkpoint": {"description": "Current active LDD checkpoint.", "type": "string"},
    "latest_timeline_event": {"description": "Latest timeline event at baseline.", "type": "string"},
    "runtime_records_count": {"description": "Runtime record count at baseline.", "type": "integer"},
    "timeline_event_count": {"description": "Timeline event count at baseline.", "type": "integer"},
    "timeline_warning_count": {"description": "Timeline warning count at baseline.", "type": "integer"},
    "active_rules_count": {"description": "Active rules count at baseline.", "type": "integer"},
    "strategy_states_count": {"description": "Strategy states count at baseline.", "type": "integer"},
    "customer_facing_readiness": {"description": "Customer-facing readiness must remain false.", "type": "boolean", "const": false, "enum": [false]},
    "operating_mode": {"description": "Current operating mode.", "type": "string"},
    "portfolio_mode": {"description": "Current portfolio mode.", "type": "string"},
    "allowed_input_fixtures": {"description": "Static fixture files a future consumer may read.", "type": "array", "items": {"type": "string"}},
    "normalized_view_model_contract": {"description": "Required normalized static view model sections.", "type": "array", "items": {"type": "string"}},
    "required_labels": {"description": "Labels that must be visible in any future static shell.", "type": "array", "items": {"type": "string"}},
    "forbidden_affordances": {"description": "Forbidden UI affordances.", "type": "array", "items": {"type": "string"}},
    "forbidden_integrations": {"description": "Forbidden integrations and runtime capabilities.", "type": "array", "items": {"type": "string"}},
    "fixture_only": {"description": "Contract is fixture-only.", "type": "boolean", "const": true, "enum": [true]},
    "read_only": {"description": "Contract is read-only.", "type": "boolean", "const": true, "enum": [true]},
    "mutation_allowed": {"description": "Mutation is disallowed.", "type": "boolean", "const": false, "enum": [false]},
    "execution_allowed": {"description": "Execution is disallowed.", "type": "boolean", "const": false, "enum": [false]},
    "credential_handling_allowed": {"description": "Credential handling is disallowed.", "type": "boolean", "const": false, "enum": [false]},
    "live_data_allowed": {"description": "Live data is disallowed.", "type": "boolean", "const": false, "enum": [false]},
    "ldd_scope_reminder": {"description": "Full-market LDD scope reminder.", "type": "string"}
  }
}
