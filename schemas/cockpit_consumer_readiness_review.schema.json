{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/loseyourself1978-blip/tianma-work-os/schemas/cockpit_consumer_readiness_review.schema.json",
  "title": "Cockpit Consumer Readiness Review",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_type",
    "review_id",
    "project",
    "subproject",
    "review_time",
    "baseline_checkpoint",
    "baseline_commit",
    "portfolio_mode",
    "view_model_file",
    "consumer_readiness_result",
    "consumer_map",
    "consumer_contract_boundaries",
    "required_consumer_safety_fields",
    "consumer_specific_readiness",
    "privacy_and_safety_review",
    "current_ldd_consumer_interpretation",
    "known_limitations",
    "blocking_issues",
    "warnings",
    "recommended_next_phase",
    "non_goals",
    "related_records",
    "related_reports"
  ],
  "properties": {
    "schema_type": {
      "type": "string",
      "enum": [
        "cockpit_consumer_readiness_review"
      ]
    },
    "review_id": {
      "type": "string"
    },
    "project": {
      "type": "string"
    },
    "subproject": {
      "type": "string"
    },
    "review_time": {
      "type": "string"
    },
    "baseline_checkpoint": {
      "type": "string"
    },
    "baseline_commit": {
      "type": "string"
    },
    "portfolio_mode": {
      "type": "string"
    },
    "view_model_file": {
      "type": "string"
    },
    "consumer_readiness_result": {
      "type": "string",
      "enum": [
        "ready",
        "ready_with_limits",
        "not_ready"
      ]
    },
    "consumer_map": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "consumer_contract_boundaries": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "required_consumer_safety_fields": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "consumer_specific_readiness": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "consumer",
          "status",
          "rationale",
          "limits"
        ],
        "properties": {
          "consumer": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "ready",
              "ready_with_limits",
              "not_ready"
            ]
          },
          "rationale": {
            "type": "string"
          },
          "limits": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "privacy_and_safety_review": {
      "type": "object",
      "additionalProperties": true
    },
    "current_ldd_consumer_interpretation": {
      "type": "object",
      "additionalProperties": true
    },
    "known_limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blocking_issues": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommended_next_phase": {
      "type": "string"
    },
    "non_goals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "related_records": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "related_reports": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
