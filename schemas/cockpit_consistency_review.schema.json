{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/loseyourself1978-blip/tianma-work-os/schemas/cockpit_consistency_review.schema.json",
  "title": "Cockpit Consistency Review",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_type",
    "review_id",
    "project",
    "subproject",
    "review_time",
    "baseline_checkpoint",
    "baseline_commit",
    "portfolio_mode",
    "cockpit_files_reviewed",
    "consistency_status",
    "warnings",
    "blocking_issues",
    "non_blocking_observations",
    "ui_readiness_score",
    "recommended_next_phase",
    "related_records"
  ],
  "properties": {
    "schema_type": {
      "type": "string",
      "enum": [
        "cockpit_consistency_review"
      ]
    },
    "review_id": {
      "type": "string"
    },
    "project": {
      "type": "string"
    },
    "subproject": {
      "type": "string"
    },
    "review_time": {
      "type": "string"
    },
    "baseline_checkpoint": {
      "type": "string"
    },
    "baseline_commit": {
      "type": "string"
    },
    "portfolio_mode": {
      "type": "string"
    },
    "cockpit_files_reviewed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "report_files_reviewed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "consistency_status": {
      "type": "string",
      "enum": [
        "passed",
        "passed_with_observations",
        "warning",
        "blocked"
      ]
    },
    "latest_active_checkpoint": {
      "type": "string"
    },
    "timeline_warning_count": {
      "type": "integer"
    },
    "active_rule_count": {
      "type": "integer"
    },
    "strategy_state_count": {
      "type": "integer"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blocking_issues": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "non_blocking_observations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "consistency_findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "ui_readiness_score": {
      "type": "number"
    },
    "recommended_next_phase": {
      "type": "string"
    },
    "explicit_confirmations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "related_records": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "related_reports": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
