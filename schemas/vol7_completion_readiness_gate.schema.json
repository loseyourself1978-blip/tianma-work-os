{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/loseyourself1978-blip/tianma-work-os/schemas/vol7_completion_readiness_gate.schema.json",
  "title": "Vol.7 Completion Readiness Gate",
  "description": "Validates the Vol.7 completion readiness gate fixture.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "phase",
    "baseline_commit",
    "vol7_completion_readiness",
    "handoff_status",
    "runtime_records_count",
    "timeline_event_count",
    "timeline_warning_count",
    "customer_facing_readiness",
    "static_shell_path",
    "static_shell_boundary",
    "completed_phase_count",
    "completed_phases",
    "required_validators_status",
    "forbidden_scope_absence_status",
    "handoff_notes",
    "recommended_next_volume",
    "recommended_next_chat_title",
    "fixture_only",
    "read_only",
    "local_static_preview_only",
    "network_allowed",
    "api_allowed",
    "mutation_allowed",
    "execution_allowed",
    "credential_handling_allowed",
    "live_data_allowed",
    "production_deployment_allowed",
    "warnings",
    "errors"
  ],
  "properties": {
    "phase": {
      "type": "string",
      "enum": ["Vol.7 Phase 7.7 - Local Static Shell Snapshot QA and Vol.7 Completion Readiness"]
    },
    "baseline_commit": {
      "type": "string",
      "enum": ["04042d1a20c4d96b5cfdab4d404c2458fb2c12a8"]
    },
    "vol7_completion_readiness": {
      "type": "string",
      "enum": ["not_ready", "ready_with_exceptions", "ready_for_handoff"]
    },
    "handoff_status": {"type": "string", "enum": ["ready"]},
    "runtime_records_count": {"type": "integer", "minimum": 106},
    "timeline_event_count": {"type": "integer", "minimum": 106},
    "timeline_warning_count": {"type": "integer", "enum": [0]},
    "customer_facing_readiness": {"type": "boolean", "enum": [false]},
    "static_shell_path": {"type": "string", "enum": ["static_shell/ldd/"]},
    "static_shell_boundary": {"type": "string", "enum": ["local_static_read_only_fixture_only_no_network_no_execution"]},
    "completed_phase_count": {"type": "integer", "enum": [8]},
    "completed_phases": {"type": "array", "items": {"type": "string"}},
    "required_validators_status": {"type": "string", "enum": ["passed"]},
    "forbidden_scope_absence_status": {"type": "string", "enum": ["passed"]},
    "handoff_notes": {"type": "array", "items": {"type": "string"}},
    "recommended_next_volume": {"type": "string", "enum": ["Vol.8"]},
    "recommended_next_chat_title": {"type": "string", "enum": ["Tianma Work OS Vol.8 — Static Shell QA Handoff / Next Product Boundary"]},
    "fixture_only": {"type": "boolean", "enum": [true]},
    "read_only": {"type": "boolean", "enum": [true]},
    "local_static_preview_only": {"type": "boolean", "enum": [true]},
    "network_allowed": {"type": "boolean", "enum": [false]},
    "api_allowed": {"type": "boolean", "enum": [false]},
    "mutation_allowed": {"type": "boolean", "enum": [false]},
    "execution_allowed": {"type": "boolean", "enum": [false]},
    "credential_handling_allowed": {"type": "boolean", "enum": [false]},
    "live_data_allowed": {"type": "boolean", "enum": [false]},
    "production_deployment_allowed": {"type": "boolean", "enum": [false]},
    "warnings": {"type": "array", "items": {"type": "string"}, "maxItems": 0},
    "errors": {"type": "array", "items": {"type": "string"}, "maxItems": 0}
  }
}
