{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/loseyourself1978-blip/tianma-work-os/schemas/cockpit_view_model_generation.schema.json",
  "title": "Cockpit View Model Generation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_type",
    "generation_id",
    "project",
    "subproject",
    "generation_time",
    "baseline_checkpoint",
    "baseline_commit",
    "portfolio_mode",
    "generator",
    "input_files",
    "output_file",
    "validation_status",
    "warnings",
    "blocking_issues",
    "generated_sections",
    "summary",
    "non_goals",
    "recommended_next_phase"
  ],
  "properties": {
    "schema_type": {
      "type": "string",
      "enum": [
        "cockpit_view_model_generation"
      ]
    },
    "generation_id": {
      "type": "string"
    },
    "project": {
      "type": "string"
    },
    "subproject": {
      "type": "string"
    },
    "generation_time": {
      "type": "string"
    },
    "baseline_checkpoint": {
      "type": "string"
    },
    "baseline_commit": {
      "type": "string"
    },
    "portfolio_mode": {
      "type": "string"
    },
    "generator": {
      "type": "string"
    },
    "input_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "output_file": {
      "type": "string"
    },
    "validation_status": {
      "type": "string"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blocking_issues": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "generated_sections": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": true
    },
    "non_goals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommended_next_phase": {
      "type": "string"
    },
    "related_documents": {
      "type": "array",
      "items": {
        "type": "string"
      }
